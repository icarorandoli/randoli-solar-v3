CREATE TABLE IF NOT EXISTS nfse_notas (  id VARCHAR PRIMARY KEY DEFAULT gen_random_uuid()::text,  project_id VARCHAR NOT NULL REFERENCES projects(id) ON DELETE CASCADE,  numero_nota TEXT,  numero_rps TEXT NOT NULL,  serie_rps TEXT NOT NULL DEFAULT '1',  codigo_verificacao TEXT,  xml_content TEXT,  link_nota TEXT,  status TEXT NOT NULL DEFAULT 'pendente',  error_message TEXT,  valor TEXT,  tomador_nome TEXT,  tomador_cpf_cnpj TEXT,  emitido_em TIMESTAMP,  created_at TIMESTAMP DEFAULT NOW(),  updated_at TIMESTAMP DEFAULT NOW());
\q
